<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teampm.mapper.GlobalFceAhpMapper">
    <resultMap id="GlobalFceAhpMap" type="com.teampm.domain.GlobalFceAhp">
        <id property="id" column="id"/>
        <result property="matrixJson" column="matrix_json"/>
        <result property="weightsJson" column="weights_json"/>
        <result property="crValue" column="cr_value"/>
        <result property="consistentFlag" column="consistent_flag"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findSingleton" resultMap="GlobalFceAhpMap">
        SELECT * FROM global_fce_ahp WHERE id = 1
    </select>

    <insert id="upsertSingleton">
        INSERT INTO global_fce_ahp (id, matrix_json, weights_json, cr_value, consistent_flag)
        VALUES (#{id}, #{matrixJson}, #{weightsJson}, #{crValue}, #{consistentFlag})
        ON DUPLICATE KEY UPDATE
            matrix_json = VALUES(matrix_json),
            weights_json = VALUES(weights_json),
            cr_value = VALUES(cr_value),
            consistent_flag = VALUES(consistent_flag),
            updated_at = CURRENT_TIMESTAMP
    </insert>
</mapper>
