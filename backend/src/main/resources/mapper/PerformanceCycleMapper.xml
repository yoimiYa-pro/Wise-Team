<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teampm.mapper.PerformanceCycleMapper">
    <resultMap id="PcMap" type="com.teampm.domain.PerformanceCycle">
        <id property="id" column="id"/>
        <result property="teamId" column="team_id"/>
        <result property="cycleType" column="cycle_type"/>
        <result property="periodStart" column="period_start"/>
        <result property="periodEnd" column="period_end"/>
        <result property="closedFlag" column="closed_flag"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="PcMap">SELECT * FROM performance_cycles WHERE id = #{id}</select>
    <select id="findByTeamId" resultMap="PcMap">SELECT * FROM performance_cycles WHERE team_id = #{teamId} ORDER BY id DESC</select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO performance_cycles (team_id, cycle_type, period_start, period_end, closed_flag)
        VALUES (#{teamId}, #{cycleType}, #{periodStart}, #{periodEnd}, #{closedFlag})
    </insert>

    <update id="closeCycle">UPDATE performance_cycles SET closed_flag = 1 WHERE id = #{id}</update>
</mapper>
