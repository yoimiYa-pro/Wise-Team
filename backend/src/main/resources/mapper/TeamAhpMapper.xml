<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teampm.mapper.TeamAhpMapper">
    <resultMap id="AhpMap" type="com.teampm.domain.TeamAhp">
        <id property="id" column="id"/>
        <result property="teamId" column="team_id"/>
        <result property="matrixJson" column="matrix_json"/>
        <result property="weightsJson" column="weights_json"/>
        <result property="crValue" column="cr_value"/>
        <result property="consistentFlag" column="consistent_flag"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findByTeamId" resultMap="AhpMap">SELECT * FROM team_ahp WHERE team_id = #{teamId}</select>

    <insert id="upsert">
        INSERT INTO team_ahp (team_id, matrix_json, weights_json, cr_value, consistent_flag)
        VALUES (#{teamId}, #{matrixJson}, #{weightsJson}, #{crValue}, #{consistentFlag})
        ON DUPLICATE KEY UPDATE
            matrix_json = VALUES(matrix_json),
            weights_json = VALUES(weights_json),
            cr_value = VALUES(cr_value),
            consistent_flag = VALUES(consistent_flag),
            updated_at = CURRENT_TIMESTAMP
    </insert>
</mapper>
